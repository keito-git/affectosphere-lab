---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import RevealObserver from "../components/RevealObserver.astro";
import { site } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  /** When true, the page is rendered without the global <main> max-width wrapper.
   *  Use for full-bleed hero pages that handle their own containers. */
  fullBleed?: boolean;
  locale?: "ja" | "en";
  /** Optional per-page social image (Open Graph / Twitter card).
   *  Pass a site-relative path like "/column-images/foo.svg".
   *  Falls back to the lab logo if omitted. */
  ogImage?: string;
  /** Optional structured data (JSON-LD) injected into <head>. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = site.description,
  fullBleed = false,
  locale = "ja",
  ogImage,
  jsonLd,
} = Astro.props;

const pageTitle = title ? `${title} | ${site.name}` : site.name;
const pathname = Astro.url.pathname;
const htmlLang = locale === "en" ? "en" : "ja";

// Absolute origin for canonical / og:url / hreflang alternates.
// Astro.site is configured in astro.config.mjs.
const origin = Astro.site ? Astro.site.origin : "https://lab.affectosphere.group";
const canonical = `${origin}${pathname}`;

// hreflang alternates: mirror the path between the JP root and the /en/ subtree.
const altPath =
  locale === "en"
    ? pathname.replace(/^\/en(\/|$)/, "/") || "/"
    : `/en${pathname.startsWith("/") ? pathname : `/${pathname}`}`;
const alternateUrl = `${origin}${altPath}`;

// Absolute OG image URL: per-page override, otherwise the lab logo.
const ogImagePath = ogImage ?? "/logo/mark-light.png";
const ogImageAbsolute = ogImagePath.startsWith("http")
  ? ogImagePath
  : `${origin}${ogImagePath}`;

const jsonLdArray = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Google Search Console site verification. -->
    <meta name="google-site-verification" content="OSnSka7rSmEHO5kcN_ZIGGYxVezPaSa1GXCBQpraRW8" />

    <!-- Canonical + hreflang alternates for the JP/EN site pair. -->
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      hreflang={locale}
      href={canonical}
    />
    <link
      rel="alternate"
      hreflang={locale === "en" ? "ja" : "en"}
      href={alternateUrl}
    />
    <link rel="alternate" hreflang="x-default" href={`${origin}/`} />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:locale" content={locale === "en" ? "en_US" : "ja_JP"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Favicon (lab logo, light-bg variant for browser tabs on white). -->
    <link rel="icon" type="image/png" href="/logo/mark.png" />
    <link rel="apple-touch-icon" href="/logo/mark.png" />

    <!-- Google Fonts: Noto Serif JP for Japanese, JetBrains Mono for code only.
         English uses Times New Roman (system font, no loading needed). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    {
      jsonLdArray.map((data) => (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(data)}
        />
      ))
    }
  </head>

  <body class="min-h-screen bg-ivory text-charcoal antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:bg-charcoal focus:px-3 focus:py-2 focus:text-ivory"
    >
      Skip to content
    </a>

    <Nav current={pathname} locale={locale} />

    <main id="main-content" class:list={[!fullBleed && "mx-auto max-w-content"]}>
      <slot />
    </main>

    <Footer locale={locale} />

    <RevealObserver />
  </body>
</html>
