---
import { site, navItems } from "../data/site";

interface Props {
  locale?: "ja" | "en";
}
const { locale = "ja" } = Astro.props;
const prefix = locale === "en" ? "/en" : "";
const sitemapLabel = locale === "en" ? "Sitemap" : "サイトマップ";
const navLabel = locale === "en" ? "Footer menu" : "フッターメニュー";
const networkLabel = locale === "en" ? "Network" : "関連サイト";
const networkSites = [
  { href: "https://daily.affectosphere.group", label: "AI Business Daily" },
  {
    href: "https://kids.affectosphere.group",
    label: locale === "en" ? "AI Business Daily Kids" : "AI Business Daily（子供版）",
  },
  {
    href: "https://fiction.affectosphere.group",
    label: locale === "en" ? "Fictional Pro" : "架空のプロフェッショナル",
  },
];
const year = new Date().getFullYear();
---

<footer class="mt-section-sm border-t border-stone bg-ivory">
  <div class="mx-auto max-w-content page-x py-16">
    <nav aria-label={navLabel}>
      <p class="font-sans text-base font-medium tracking-wide text-slate mb-6">
        {sitemapLabel}
      </p>
      <ul class="grid grid-cols-2 gap-x-8 gap-y-3 sm:grid-cols-3 md:grid-cols-4">
        {
          navItems.map((item) => (
            <li>
              <a
                href={`${prefix}${item.href}`}
                class="link-amber font-heading text-sm text-charcoal"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <nav aria-label={networkLabel} class="mt-12">
      <p class="font-sans text-base font-medium tracking-wide text-slate mb-6">
        {networkLabel}
      </p>
      <ul class="flex flex-wrap gap-x-8 gap-y-3">
        {
          networkSites.map((item) => (
            <li>
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class="link-amber font-heading text-sm text-charcoal"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <div class="border-t border-stone">
    <div
      class="mx-auto flex max-w-content flex-col items-start justify-between gap-2 page-x py-6 text-xs text-slate md:flex-row md:items-center"
    >
      <p>&copy; {year} {site.name}. All rights reserved.</p>
      <p class="font-sans uppercase tracking-[0.14em] font-medium">
        Built with Astro &middot; Tailwind CSS
      </p>
    </div>
  </div>
</footer>
