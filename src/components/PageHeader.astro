---
// Top-of-page header used by every content page (About, Research, ...).
// Pairs an eyebrow kicker with a large display title and an optional subtitle.
// `compact` shrinks the title one step down — used by long Japanese titles
// (e.g. on research domain detail pages) where the default size overflows.
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  compact?: boolean;
}
const { eyebrow, title, subtitle, compact = false } = Astro.props;

const titleFontSize = compact
  ? "clamp(1.75rem, 3.2vw, 2.75rem)"
  : "clamp(2.25rem, 4.5vw, 4rem)";
---

<section class="mx-auto max-w-content page-x pt-24 md:pt-32">
  {eyebrow && <p class="eyebrow reveal">{eyebrow}</p>}
  <h1
    class="reveal mt-4 font-display font-medium tracking-tight text-charcoal"
    style={`font-size: ${titleFontSize}; line-height: 1.12;`}
  >
    {title}
  </h1>
  {
    subtitle && (
      <p class="reveal mt-6 max-w-prose text-lg leading-relaxed text-slate md:text-xl">
        {subtitle}
      </p>
    )
  }
</section>
