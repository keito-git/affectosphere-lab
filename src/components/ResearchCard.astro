---
import type { ResearchCard } from "../data/research";

interface Props {
  card: ResearchCard;
}
const { card } = Astro.props;
---

<article class="surface-card reveal flex h-full flex-col">
  <p class="eyebrow">{card.pillar}</p>
  <h3 class="mt-3 font-heading text-xl font-medium text-charcoal">
    {card.title}
  </h3>
  {card.titleJa && (
    <p class="mt-1 font-display text-sm text-slate">{card.titleJa}</p>
  )}
  <p class="mt-3 text-sm leading-relaxed text-charcoal/85">{card.summary}</p>
  <div class="mt-auto pt-6">
    <p class="font-sans text-[0.75rem] uppercase tracking-[0.14em] text-amber font-medium">
      {card.status}
    </p>
  </div>
</article>
