---
// Reusable section header with eyebrow + title + optional lede.
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  align?: "left" | "center";
}
const { eyebrow, title, lede, align = "left" } = Astro.props;
---

<header
  class:list={[
    "reveal mb-10 md:mb-14",
    align === "center" ? "text-center mx-auto max-w-prose" : "max-w-prose",
  ]}
>
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <h2 class="font-heading text-2xl font-medium tracking-tight text-charcoal md:text-3xl">
    {title}
  </h2>
  {
    lede && (
      <p class="mt-4 text-base leading-relaxed text-slate md:text-lg">{lede}</p>
    )
  }
</header>
