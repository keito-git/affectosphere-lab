---
import type { NewsItem } from "../data/news";

interface Props {
  item: NewsItem;
  locale?: "ja" | "en";
}
const { item, locale = "ja" } = Astro.props;

const [y, m, d] = item.date.split("-");
const monthsEn = [
  "January", "February", "March", "April", "May", "June",
  "July", "August", "September", "October", "November", "December",
];
const display =
  locale === "en"
    ? `${monthsEn[Number(m) - 1]} ${Number(d)}, ${y}`
    : `${y}年${Number(m)}月${Number(d)}日`;
---

<li class="reveal grid gap-2 border-b border-stone py-5 last:border-b-0 md:grid-cols-[10rem_8rem_1fr] md:gap-6">
  <time class="font-sans text-xs text-slate font-medium" datetime={item.date}>
    {display}
  </time>
  <span class="font-sans text-xs uppercase tracking-[0.14em] text-amber font-medium">
    {item.label}
  </span>
  <p class="text-sm text-charcoal md:text-base">{item.body}</p>
</li>
