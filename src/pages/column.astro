---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";

const posts = (await getCollection("column-ja")).sort((a, b) =>
  b.data.date.localeCompare(a.data.date)
);

function formatDate(iso: string): string {
  const [y, m, d] = iso.split("-");
  return `${y} / ${m} / ${d}`;
}
---

<BaseLayout
  title="Column"
  description="Affectosphere Group の研究を、ビジネス・実務目線で読み解くコラム。5 分で読めるように書いています。"
  fullBleed
>
  <PageHeader
    eyebrow="Column"
    title="研究をビジネスの言葉に。"
    subtitle="Affectosphere Group の研究を、ビジネスや実務の意思決定に役立つ形で書き直しています。1 本 5 分で読めます。"
    wideSubtitle
  />

  <section class="mx-auto mt-section-sm max-w-content page-x">
    {
      posts.length === 0 ? (
        <p class="reveal text-base text-slate">
          No posts yet. The first column entries will appear here shortly.
        </p>
      ) : (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <a
              href={`/column/${post.slug}/`}
              class="surface-card reveal flex h-full flex-col"
            >
              {post.data.image && (
                <img
                  src={post.data.image}
                  alt={post.data.imageAlt ?? ""}
                  class="-m-6 mb-4 aspect-[16/9] w-[calc(100%+3rem)] max-w-none border-b border-stone object-cover"
                  loading="lazy"
                />
              )}
              <p class="eyebrow">{formatDate(post.data.date)}</p>
              <h3 class="mt-3 font-heading text-lg font-medium text-charcoal">
                {post.data.title}
              </h3>
              <p class="mt-3 text-sm leading-relaxed text-charcoal/85">
                {post.data.excerpt}
              </p>
              <div class="mt-auto pt-6 flex items-center justify-between">
                <span class="font-mono text-[0.65rem] uppercase tracking-[0.18em] text-slate">
                  {post.data.readingMinutes} min read
                </span>
                <span class="link-amber font-heading text-sm tracking-wide">
                  Read &rarr;
                </span>
              </div>
            </a>
          ))}
        </div>
      )
    }
  </section>

  <div class="h-section-sm" aria-hidden="true"></div>
</BaseLayout>
