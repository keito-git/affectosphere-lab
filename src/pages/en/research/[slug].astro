---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { researchDomains } from "../../../data/research-domains.en";

export function getStaticPaths() {
  return researchDomains.map((d) => ({
    params: { slug: d.slug },
    props: { domain: d },
  }));
}

const { domain } = Astro.props;

// Sibling domains for the bottom "Other research themes" navigation.
const siblings = researchDomains.filter((d) => d.slug !== domain.slug);

const narrative = domain.narrative ?? [];
---

<BaseLayout
  title={domain.title}
  description={domain.summary}
  fullBleed
  locale="en"
>
  <!-- Hero header: domain image as background with ivory wash for text contrast. -->
  <section
    class="relative isolate overflow-hidden min-h-[60vh]"
    aria-labelledby="domain-hero"
  >
    <div
      class="absolute inset-0 bg-cover bg-center"
      style={`background-image: url('${domain.image}');`}
      aria-hidden="true"
    ></div>
    <div
      class="absolute inset-0 bg-gradient-to-b from-ivory/65 via-ivory/40 to-ivory/70"
      aria-hidden="true"
    ></div>

    <div class="relative z-10 mx-auto max-w-content page-x pt-24 pb-16 md:pt-32 md:pb-20 text-center">
      <p class="font-display text-sm italic text-slate reveal">Research</p>
      <h1
        id="domain-hero"
        class="reveal mt-4 font-display font-bold tracking-tight text-charcoal"
        style="font-size: clamp(1.75rem, 3.2vw, 2.75rem); line-height: 1.12; text-shadow: 0 1px 2px rgba(250,250,247,0.85), 0 0 28px rgba(250,250,247,0.95);"
      >
        {domain.title}
      </h1>
      <p
        class="reveal mt-6 font-bold text-lg leading-relaxed text-charcoal md:text-xl"
        style="text-shadow: 0 1px 2px rgba(250,250,247,0.8), 0 0 20px rgba(250,250,247,0.85);"
      >
        {domain.summary}
      </p>
    </div>
  </section>

  <!-- Overview: what we work on. -->
  {domain.longDescription && (
    <section class="mx-auto mt-section-sm max-w-content page-x">
      <div class="reveal grid gap-8 md:grid-cols-[16rem_1fr] md:gap-14">
        <p class="font-display text-xl italic text-slate">What we work on</p>
        <p
          class="font-display text-lg leading-relaxed text-charcoal md:text-xl"
          style="line-height: 1.85;"
        >
          {domain.longDescription}
        </p>
      </div>
    </section>
  )}

  <!-- Findings. -->
  {domain.findings && (
    <section class="mx-auto mt-section-sm max-w-content page-x">
      <div class="reveal grid gap-8 md:grid-cols-[16rem_1fr] md:gap-14">
        <p class="font-display text-xl italic text-slate">What we are finding</p>
        <p
          class="font-display text-lg leading-relaxed text-charcoal md:text-xl"
          style="line-height: 1.85;"
        >
          {domain.findings}
        </p>
      </div>
    </section>
  )}

  <!-- Narrative body: paragraphs interleaved with figures. -->
  {narrative.length > 0 && (
    <section class="mx-auto mt-section max-w-content page-x" aria-labelledby="narrative-heading">
      <header class="reveal mb-10 md:mb-14">
        <p class="font-display text-sm italic text-slate">Research notes</p>
        <h2
          id="narrative-heading"
          class="mt-3 font-display text-3xl font-medium text-charcoal md:text-4xl"
        >
          Research narrative
        </h2>
      </header>

      <div class="flex flex-col gap-12 md:gap-16">
        {narrative.map((block) => (
          block.figure ? (
            <div class="reveal grid items-start gap-8 md:grid-cols-[1fr_28rem] md:gap-12">
              <p
                class="font-display text-lg leading-relaxed text-charcoal md:text-xl"
                style="line-height: 1.95;"
              >
                {block.text}
              </p>
              <figure class="md:max-w-[28rem]">
                <img
                  src={block.figure.src}
                  alt={block.figure.alt}
                  loading="lazy"
                  class="w-full border border-stone bg-white shadow-card"
                />
                <figcaption class="mt-3 font-display text-sm italic leading-relaxed text-slate">
                  {block.figure.caption}
                </figcaption>
              </figure>
            </div>
          ) : (
            <p
              class="reveal font-display text-lg leading-relaxed text-charcoal md:text-xl"
              style="line-height: 1.95;"
            >
              {block.text}
            </p>
          )
        ))}
      </div>
    </section>
  )}

  {narrative.length === 0 && (
    <section class="mx-auto mt-section max-w-content page-x">
      <div class="reveal max-w-prose font-display text-base leading-relaxed text-slate">
        This domain is ongoing; papers and presentations will be released as they appear.
      </div>
    </section>
  )}

  <!-- Sibling navigation. -->
  <section class="mx-auto mt-section max-w-content page-x">
    <div class="reveal border-t border-stone pt-8">
      <h2 class="font-display text-xl font-medium text-charcoal md:text-2xl">
        Other research domains
      </h2>
      <ul class="mt-6 grid gap-3 md:grid-cols-2 max-w-prose">
        {siblings.map((s) => (
          <li>
            <a
              href={`/en/research/${s.slug}/`}
              class="link-amber font-display text-base text-charcoal"
            >
              {s.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <div class="h-section-sm" aria-hidden="true"></div>
</BaseLayout>
