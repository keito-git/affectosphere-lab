---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import ColumnGrid from "../../components/ColumnGrid.astro";
import Pagination from "../../components/Pagination.astro";

const PAGE_SIZE = 15;

const allPosts = (await getCollection("column-en")).sort((a, b) =>
  b.data.date.localeCompare(a.data.date)
);
const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));
const posts = allPosts.slice(0, PAGE_SIZE);
---

<BaseLayout
  title="Column"
  description="Plain-language columns from Affectosphere Group — research findings rewritten for business and practice. 5-minute reads."
  fullBleed
  locale="en"
>
  <PageHeader
    eyebrow="Column"
    title="Research, in business language."
    subtitle="We rewrite Affectosphere Group's research into something useful for business and practical decision-making. Each piece is a 5-minute read."
    wideSubtitle
  />

  <section class="mx-auto mt-section-sm max-w-content page-x">
    {
      posts.length === 0 ? (
        <p class="reveal text-base text-slate">
          No posts yet. The first column entries will appear here shortly.
        </p>
      ) : (
        <ColumnGrid posts={posts} hrefBase="/en/column" />
      )
    }
    <Pagination current={1} total={totalPages} basePath="/en/column" />
  </section>

  <div class="h-section-sm" aria-hidden="true"></div>
</BaseLayout>
