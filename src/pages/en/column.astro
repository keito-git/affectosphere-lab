---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { columnPosts } from "../../data/column.en";

function formatDate(iso: string): string {
  const [y, m, d] = iso.split("-");
  return `${y} / ${m} / ${d}`;
}
---

<BaseLayout
  title="Column"
  description="Blog and column posts from Affectosphere Group."
  fullBleed
  locale="en"
>
  <PageHeader
    eyebrow="Column"
    title="Notes from the lab."
    subtitle="Short essays, blog posts, and plain-language companions to the lab's papers."
  />

  <section class="mx-auto mt-section-sm max-w-content page-x">
    {
      columnPosts.length === 0 ? (
        <p class="reveal max-w-prose text-base text-slate">
          No posts yet.  The first column entries will appear here shortly.
        </p>
      ) : (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {columnPosts.map((post) => (
            <article class="surface-card reveal flex h-full flex-col">
              <p class="eyebrow">{formatDate(post.date)}</p>
              <h3 class="mt-3 font-heading text-lg font-medium text-charcoal">
                {post.title}
              </h3>
              <p class="mt-3 text-sm leading-relaxed text-charcoal/85">
                {post.excerpt}
              </p>
              <div class="mt-auto pt-6">
                {post.placeholder ? (
                  <span class="font-mono text-[0.65rem] uppercase tracking-[0.18em] text-amber">
                    Coming soon
                  </span>
                ) : (
                  <a
                    href={post.href ?? `/en/column/${post.slug}/`}
                    class="link-amber font-heading text-sm tracking-wide"
                  >
                    Read &rarr;
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>
      )
    }
  </section>

  <!-- TODO(inoshita): when a post is ready, drop the body as Markdown
       under `src/content/column/<slug>.md` (Astro Content Collection)
       and remove the `placeholder` flag in `src/data/column.en.ts`.  At that
       point also add a `src/pages/en/column/[slug].astro` dynamic route for
       the full read. -->

  <div class="h-section-sm" aria-hidden="true"></div>
</BaseLayout>
