---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Thank you"
  description="Your message has been received."
  fullBleed
  locale="en"
>
  <section class="mx-auto max-w-content page-x pt-32 pb-section">
    <div class="reveal max-w-prose">
      <p class="font-display text-sm italic text-slate">Thank you</p>
      <h1
        class="mt-4 font-display font-medium tracking-tight text-charcoal"
        style="font-size: clamp(2.25rem, 4.5vw, 4rem); line-height: 1.12;"
      >
        Thank you for your message
      </h1>
      <p class="mt-6 font-display text-lg leading-relaxed text-charcoal md:text-xl" style="line-height: 1.85;">
        We have received your inquiry and appreciate you reaching out.
        We will typically reply to the email address you provided within 2 to 3 business days.
        Thank you for your patience.
      </p>
      <p class="mt-10">
        <a href="/en/" class="link-amber font-display text-base">
          &larr; Back to home
        </a>
      </p>
    </div>
  </section>

  <div class="h-section-sm" aria-hidden="true"></div>
</BaseLayout>
