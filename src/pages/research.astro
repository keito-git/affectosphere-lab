---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { researchDomains } from "../data/research-domains";
---

<BaseLayout
  title="Research"
  description="Affectosphere Groupの十の研究領域 ― 感情AIの倫理から、認識・内部理解・人間とのインタラクション、ビジネス、開発まで。"
  fullBleed
>
  <PageHeader
    eyebrow="Research"
    title="十の研究領域。"
    subtitle="Affectosphere Group が取り組んでいる、感情AIをめぐる十の研究領域です。それぞれの領域は独立に深められつつも、互いに往復しながら全体を編んでいます。"
    wideSubtitle
  />

  <section class="mx-auto mt-section-sm max-w-content page-x">
    <div class="grid gap-6 md:grid-cols-2">
      {
        researchDomains.map((d) => (
          <a
            href={`/research/${d.slug}/`}
            class="reveal group relative flex h-full flex-col overflow-hidden border border-stone shadow-card transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-card-hover"
          >
            <div
              class="absolute inset-0 bg-cover bg-center transition-transform duration-500 group-hover:scale-[1.02]"
              style={`background-image: url('${d.image}');`}
              aria-hidden="true"
            />
            <div
              class="absolute inset-0 bg-ivory/55 transition-colors duration-300 group-hover:bg-ivory/45"
              aria-hidden="true"
            />
            <div class="relative z-10 flex h-full flex-col p-6 min-h-[240px]">
              <h2 class="font-display text-2xl font-bold text-charcoal">
                {d.title}
              </h2>
              <p class="mt-4 font-display text-base font-bold leading-relaxed text-charcoal">
                {d.summary}
              </p>
              <span class="mt-auto pt-6 font-heading text-sm font-bold tracking-wide text-charcoal transition-colors group-hover:text-amber">
                詳しく見る &rarr;
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <div class="h-section-sm" aria-hidden="true"></div>
</BaseLayout>
