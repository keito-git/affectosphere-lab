---
import BaseLayout from "../layouts/BaseLayout.astro";
import { grants, totalGrants } from "../data/grants";
---

<BaseLayout
  title="研究費"
  description="Affectosphere Group が獲得している競争的資金・研究助成の一覧。"
  fullBleed
>
  <section class="mx-auto max-w-content page-x pt-24 md:pt-32">
    <h1
      class="reveal font-display font-medium tracking-tight text-charcoal"
      style="font-size: clamp(2.25rem, 4.5vw, 4rem); line-height: 1.12;"
    >
      Grants
    </h1>
    <p class="reveal mt-6 max-w-prose font-display text-lg leading-relaxed text-slate md:text-xl">
      競争的資金・研究助成の一覧(全 {totalGrants} 件)。
    </p>
  </section>

  <section class="mx-auto mt-section-sm max-w-content page-x">
    <ul class="w-full">
      {
        grants.map((g) => (
          <li class="reveal border-b border-stone py-6 last:border-b-0">
            <p class="font-display text-base italic text-slate">{g.period}</p>
            <p class="mt-2 font-display text-lg text-charcoal md:text-xl" style="line-height: 1.55;">
              {g.projectTitle}
            </p>
            <p class="mt-2 font-display text-base text-charcoal/85">
              {g.program}
              {g.organization && (
                <span class="text-slate"> / {g.organization}</span>
              )}
            </p>
            <div class="mt-3 flex flex-wrap gap-x-6 gap-y-1 font-display text-sm italic text-slate">
              {g.role && <span>役割: {g.role}</span>}
              {g.amount && <span>金額: {g.amount}</span>}
              {g.coInvestigators && <span>共同研究者: {g.coInvestigators}</span>}
            </div>
          </li>
        ))
      }
    </ul>
  </section>

  <div class="h-section-sm" aria-hidden="true"></div>
</BaseLayout>
